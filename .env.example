# 复制本文件为 .env 并填入你的 API（.env 已被 .gitignore，切勿提交真实密钥！）
# HelloAgentsLLM 走 OpenAI 兼容接口，按 base_url 自动识别 provider。

LLM_API_KEY=在此填入你的_API_Key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_ID=deepseek-chat
# LLM_TIMEOUT=60

# ---- 其它可选 provider（替换 BASE_URL / MODEL_ID）----
# 通义 Qwen : https://dashscope.aliyuncs.com/compatible-mode/v1   qwen-plus
# 魔搭(免费): https://api-inference.modelscope.cn/v1/             Qwen/Qwen2.5-72B-Instruct
# Kimi      : https://api.moonshot.cn/v1                          moonshot-v1-8k
# 智谱 GLM  : https://open.bigmodel.cn/api/paas/v4                glm-4
# 学校/自建代理：填到 /v1 为止，不要带 /chat/completions
